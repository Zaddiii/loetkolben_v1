{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
		    "toolchainFile": "${sourceDir}/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
            }
        },
        {
            "name": "Debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FIRMWARE_VARIANT": "TEST"
            }
        },
        {
            "name": "Debug-Iron",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FIRMWARE_VARIANT": "IRON"
            }
        },
        {
            "name": "Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FIRMWARE_VARIANT": "TEST"
            }
        },
        {
            "name": "Release-Iron",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FIRMWARE_VARIANT": "IRON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug"
        },
        {
            "name": "Debug-Iron",
            "configurePreset": "Debug-Iron"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        },
        {
            "name": "Release-Iron",
            "configurePreset": "Release-Iron"
        }
    ]
}